{
  "name": "root",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build": "turbo run build",
    "generate": "turbo run generate --filter=@valko-ui/docs",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "publish-packages": "changeset version && changeset publish"
  },
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "nodemon": "^3.1.14",
    "pre-commit": "^2.0.0",
    "turbo": "^2.9.16"
  },
  "pre-commit": [
    "lint",
    "test"
  ]
}
